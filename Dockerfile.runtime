FROM node:22-bookworm-slim

ARG CLAUDE_CODE_VERSION=2.1.198

ENV DISABLE_AUTOUPDATER=1 \
    CLAUDE_CODE_SUBPROCESS_ENV_SCRUB=1

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates bash curl git tar bubblewrap socat ripgrep jq python3 \
    && rm -rf /var/lib/apt/lists/*

COPY scripts/install-claude-code /usr/local/bin/install-claude-code
RUN chmod +x /usr/local/bin/install-claude-code \
    && /usr/local/bin/install-claude-code "${CLAUDE_CODE_VERSION}"

COPY dist/cc-connect/linux-amd64/cc-connect /usr/local/bin/cc-connect
RUN chmod +x /usr/local/bin/cc-connect

# MCP servers are configured in .mcp.json. The built-in SteamCMD MCP is an HTTP
# sidecar; custom stdio MCP executables/config/data can live under /mcp.
COPY scripts/start /usr/local/bin/ck3qqbot-start
COPY scripts/doctor /usr/local/bin/ck3qqbot-doctor
COPY scripts/prepare-runtime-config /usr/local/bin/ck3qqbot-prepare-runtime-config
COPY scripts/runtime-entrypoint /usr/local/bin/ck3qqbot-runtime-entrypoint
RUN chmod +x /usr/local/bin/ck3qqbot-start /usr/local/bin/ck3qqbot-doctor /usr/local/bin/ck3qqbot-prepare-runtime-config /usr/local/bin/ck3qqbot-runtime-entrypoint \
    && mkdir -p /bot /home/node/.claude \
    && chown -R node:node /bot /home/node

WORKDIR /bot
ENTRYPOINT ["/usr/local/bin/ck3qqbot-runtime-entrypoint"]
CMD ["/usr/local/bin/ck3qqbot-start"]
