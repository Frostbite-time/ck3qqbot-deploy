#!/usr/bin/env bash
set -euo pipefail

version="${1:-${CLAUDE_CODE_VERSION:-}}"
install_path="${CLAUDE_CODE_INSTALL_PATH:-/usr/local/bin/claude}"
download_base_url="${CLAUDE_CODE_DOWNLOAD_BASE_URL:-https://downloads.claude.ai/claude-code-releases}"

if [[ -z "${version}" ]]; then
  echo "usage: install-claude-code VERSION" >&2
  exit 2
fi

if [[ ! "${version}" =~ ^[0-9]+\.[0-9]+\.[0-9]+(-[^[:space:]]+)?$ ]]; then
  echo "invalid Claude Code version: ${version}" >&2
  exit 2
fi

case "$(uname -s)" in
  Linux) os="linux" ;;
  Darwin) os="darwin" ;;
  *) echo "unsupported operating system: $(uname -s)" >&2; exit 2 ;;
esac

case "$(uname -m)" in
  x86_64 | amd64) arch="x64" ;;
  arm64 | aarch64) arch="arm64" ;;
  *) echo "unsupported architecture: $(uname -m)" >&2; exit 2 ;;
esac

if [[ "${os}" == "linux" ]]; then
  if [[ -f /lib/libc.musl-x86_64.so.1 || -f /lib/libc.musl-aarch64.so.1 ]] || ldd /bin/sh 2>&1 | grep -q musl; then
    platform="linux-${arch}-musl"
  else
    platform="linux-${arch}"
  fi
else
  platform="${os}-${arch}"
fi

tmp_dir="$(mktemp -d)"
cleanup() {
  rm -rf "${tmp_dir}"
}
trap cleanup EXIT

manifest="${tmp_dir}/manifest.json"
binary="${tmp_dir}/claude"

curl -fsSL "${download_base_url}/${version}/manifest.json" -o "${manifest}"
checksum="$(jq -r --arg platform "${platform}" '.platforms[$platform].checksum // empty' "${manifest}")"
if [[ ! "${checksum}" =~ ^[a-f0-9]{64}$ ]]; then
  echo "platform ${platform} not found in Claude Code ${version} manifest" >&2
  exit 1
fi

curl -fsSL "${download_base_url}/${version}/${platform}/claude" -o "${binary}"
printf '%s  %s\n' "${checksum}" "${binary}" | sha256sum -c -
install -m 0755 "${binary}" "${install_path}"
"${install_path}" --version
