###############################################################################
# Compose Project Scope
#
# These values affect Docker Compose naming and the shared Compose network.
###############################################################################

# Names the Compose project, which also prefixes containers, networks, and other Compose-managed resources.
COMPOSE_PROJECT_NAME=ck3qqbot


###############################################################################
# Runtime Endpoint Scope
#
# These values are passed into the runtime container as environment variables.
# The default Claude Code settings scrub these variables from sandboxed Bash
# subprocesses, but cc-connect and Claude Code still need them in the parent
# runtime process to connect to OneBot and the model provider.
###############################################################################

# OneBot v11 WebSocket endpoint visible to cc-connect.
CK3QQBOT_ONEBOT_WS_URL=ws://host.docker.internal:3001

# OneBot service token; leave empty if the endpoint does not require one.
CK3QQBOT_ONEBOT_TOKEN=change-me

# Anthropic Messages-compatible provider base URL. Do not add /v1 here when the
# provider expects Claude Code to request /v1/messages itself.
CK3QQBOT_CLAUDE_PROVIDER_BASE_URL=https://example.com

# Anthropic-compatible provider API key passed to Claude Code through cc-connect.
CK3QQBOT_CLAUDE_PROVIDER_API_KEY=change-me

# Model name passed to Claude Code through cc-connect's provider configuration.
CK3QQBOT_CLAUDE_PROVIDER_MODEL=ops-4.8


###############################################################################
# OneBot MCP Scope
#
# These values configure the separate onebot-mcp HTTP MCP container. Runtime
# uses this service through Compose DNS, but onebot-mcp is its own service and
# can be configured independently from cc-connect's direct OneBot connection.
###############################################################################

# Stable onebot-mcp image used by docker-compose.yml. You can replace this with
# a digest pin, for example ghcr.io/frostbite-time/onebot-mcp@sha256:...
CK3QQBOT_ONEBOT_MCP_IMAGE=ghcr.io/frostbite-time/onebot-mcp:v0.1.2

# OneBot platform adapter used by onebot-mcp; supported values are napcat,
# llonebot, and lagrange.
CK3QQBOT_ONEBOT_MCP_PLATFORM=napcat

# Internal Compose-only port used by the onebot-mcp HTTP MCP server. This is not published to the Docker host.
CK3QQBOT_ONEBOT_MCP_PORT=3000

# Token accepted by onebot-mcp for HTTP MCP requests from Claude Code.
CK3QQBOT_ONEBOT_MCP_TOKEN=change-me

# OneBot action timeout used by onebot-mcp when calling the OneBot backend.
CK3QQBOT_ONEBOT_MCP_ACTION_TIMEOUT_MS=10000

# Maximum JSON-RPC request body size accepted by onebot-mcp.
CK3QQBOT_ONEBOT_MCP_MAX_BODY_BYTES=1048576


###############################################################################
# SteamCMD MCP Scope
#
# These values configure the separate SteamCMD HTTP MCP sidecar and the updater
# access token used for its internal download API.
###############################################################################

# Internal Compose-only port used by the SteamCMD HTTP MCP sidecar. This is not published to the Docker host.
CK3QQBOT_STEAMCMD_MCP_PORT=18032

# Token used by Claude Code HTTP MCP requests to steamcmd-sidecar.
CK3QQBOT_STEAMCMD_MCP_TOKEN=change-me

# Token used by updater/updater-scheduler internal HTTP API requests to steamcmd-sidecar.
CK3QQBOT_STEAMCMD_INTERNAL_TOKEN=change-me

# Maximum preflight size in KiB for bot-facing SteamCMD MCP depot/workshop downloads; 0 disables the guard.
CK3QQBOT_STEAMCMD_MCP_MAX_DOWNLOAD_KIB=0

# Bot-visible path for files written by the SteamCMD MCP sidecar download root.
CK3QQBOT_STEAMCMD_MCP_RUNTIME_DOWNLOAD_ROOT=/bot/steam-downloads

# Maximum seconds the SteamCMD MCP size preflight may spend on Steam API or app_info_print requests.
CK3QQBOT_STEAMCMD_MCP_PREFLIGHT_TIMEOUT_SEC=60

# Maximum bytes of app_info_print output captured during depot size preflight.
CK3QQBOT_STEAMCMD_APP_INFO_OUTPUT_MAX_BYTES=20971520

# Steam PublishedFile details endpoint used to preflight Workshop file_size; normally do not change this.
CK3QQBOT_STEAM_WORKSHOP_DETAILS_URL=https://api.steampowered.com/ISteamRemoteStorage/GetPublishedFileDetails/v1/


###############################################################################
# Runtime Sandbox Scope
#
# Runtime uses Claude Code's weaker nested Bash sandbox in a non-root container
# process. docker-compose.yml grants the runtime service seccomp/appArmor/
# systempaths relaxations needed by that sandbox. Ubuntu 24.04+ hosts also need:
#   kernel.apparmor_restrict_unprivileged_userns = 0
###############################################################################

# Linux user inside the runtime image used after the entrypoint fixes ownership of mounted writable directories.
CK3QQBOT_RUNTIME_USER=node


###############################################################################
# Host Mount Scope
#
# These paths are on the Docker host and are mounted into one or more containers.
# Use absolute paths in real deployments if the Compose working directory may
# change.
###############################################################################

# Host directory containing cc-connect.toml, claude-settings.json, CLAUDE.md, and prune rules.
CK3QQBOT_CONFIG_INPUT=./config

# Host directory mounted at /runtime for generated runtime config and cc-connect runtime data.
CK3QQBOT_RUNTIME_STATE=./runtime

# Host directory mounted as the CK3 knowledge tree; updater writes it and runtime reads it.
CK3QQBOT_KNOWLEDGE=./knowledge

# Host directory mounted at /bot/bot-memory for bot-owned persistent memory files.
CK3QQBOT_BOT_MEMORY=./bot-memory

# Host directory mounted at /bot/bot-tmp for bot-owned temporary workspace files.
CK3QQBOT_BOT_TMP=./bot-tmp

# Host directory shared read-write between runtime and onebot-mcp for files that may be uploaded through OneBot MCP.
CK3QQBOT_ONEBOT_FILES=./onebot-files

# Host directory mounted at /update-state for READY, .updating, and runtime/updater handshake markers.
CK3QQBOT_UPDATE_STATE=./update-state

# Host directory mounted at /mcp for optional user-owned MCP binaries and configs.
CK3QQBOT_MCP=./mcp

# Host directory mounted at /reports for updater and pruner reports.
CK3QQBOT_REPORTS=./reports

# Host directory mounted at /steam for persistent SteamCMD login/cache state.
CK3QQBOT_STEAMCMD_STATE=./steamcmd

# Host directory mounted at /downloads for SteamCMD MCP downloads requested by the runtime bot.
CK3QQBOT_STEAMCMD_DOWNLOADS=./steam-downloads


###############################################################################
# Runtime Config Scope
#
# These values tell the runtime container which config input files to copy into
# writable runtime locations before starting cc-connect and Claude Code.
###############################################################################

# Source path inside the runtime container for the cc-connect config template.
CK3QQBOT_CC_CONNECT_CONFIG_SRC=/config-input/cc-connect.toml

# Source path inside the runtime container for the Claude Code user settings template.
CK3QQBOT_CLAUDE_SETTINGS_SRC=/config-input/claude-settings.json

# Source path inside the runtime container for the project CLAUDE.md prompt file.
CK3QQBOT_CLAUDE_MD_SRC=/config-input/CLAUDE.md

# Runtime Claude config directory mounted below /runtime; contains generated settings and Claude session state.
CK3QQBOT_CLAUDE_HOME=/runtime/claude-home


###############################################################################
# Runtime Watchdog Scope
#
# These values control how runtime responds to update-state markers and how it
# stops or restarts cc-connect/Claude Code around knowledge updates.
###############################################################################

# Maximum seconds updater waits for runtime to confirm internal services are stopped.
CK3QQBOT_RUNTIME_CONFIRM_TIMEOUT_SEC=120

# Seconds between runtime watchdog checks for READY and .updating state changes.
CK3QQBOT_RUNTIME_WATCHDOG_INTERVAL_SEC=2

# Maximum seconds runtime gives internal services to stop after .updating appears.
CK3QQBOT_RUNTIME_SHUTDOWN_TIMEOUT_SEC=30

# Seconds runtime waits after .updating disappears before restarting internal services.
CK3QQBOT_RUNTIME_RESTART_DELAY_SEC=10


###############################################################################
# Steam And Update Scope
#
# These values control what the updater downloads, when it cleans managed
# knowledge directories, and how ck3-pruner is allowed to delete files.
###############################################################################

# Steam app ID for Crusader Kings III.
CK3QQBOT_STEAM_APP_ID=1158310

# Comma-separated depot list for download_depot; each item is depot_id or depot_id:manifest_id.
# Leave empty to skip all base-game depot downloads and update only configured Workshop items.
CK3QQBOT_BASE_GAME_DEPOT_IDS=1158311

# Optional comma-separated Workshop item IDs; leave empty to update only the configured base-game depots.
CK3QQBOT_WORKSHOP_MOD_IDS=

# Minimum free disk space in KiB required before SteamCMD download steps; 0 disables this guard.
CK3QQBOT_MIN_FREE_KIB=0

# Whether updater deletes managed base_game/workshop knowledge directories before downloading fresh files.
CK3QQBOT_CLEAN_BEFORE_UPDATE=false

# Whether ck3-pruner only writes reports without deleting files; set false only after inspecting reports.
CK3QQBOT_PRUNE_DRY_RUN=true

# Maximum fraction of scanned files ck3-pruner may delete before it aborts as a safety guard.
CK3QQBOT_MAX_DELETE_RATIO=0.95

# Whether ck3-pruner removes empty directories after deleting files.
CK3QQBOT_DELETE_EMPTY_DIRS=true

# Steam account username used with cached SteamCMD login state; never put the password or Steam Guard code here.
CK3QQBOT_STEAM_USER=

# Seconds between SteamCMD progress snapshots during long download steps; 0 disables progress snapshots.
CK3QQBOT_STEAMCMD_PROGRESS_INTERVAL_SEC=30

# Seconds between updater polls of the SteamCMD sidecar task status.
CK3QQBOT_STEAMCMD_TASK_POLL_SEC=2


###############################################################################
# Update Scheduler Scope
#
# These values affect only the long-running updater-scheduler service. Manual
# one-shot updates still use the same update script but do not sleep on this
# schedule.
###############################################################################

# Desired seconds between successful knowledge updates when scheduler is running.
CK3QQBOT_UPDATE_INTERVAL_SEC=86400

# Whether scheduler should attempt an update immediately when the scheduler container starts.
CK3QQBOT_UPDATE_RUN_ON_START=false

# Whether scheduler uses /update-state/READY ready_at as the schedule baseline instead of container start time.
CK3QQBOT_UPDATE_SCHEDULE_FROM_READY=true

# Seconds between scheduler state checks; this is the polling cadence, not the update interval.
CK3QQBOT_UPDATE_SCHEDULER_POLL_SEC=300

# Seconds scheduler waits before retrying after a failed update attempt or a missing READY after an attempt.
CK3QQBOT_UPDATE_FAILURE_BACKOFF_SEC=60


###############################################################################
# Real Steam Smoke Test Scope
#
# These values are used only by ck3qqbot-steam-smoke-download. The smoke test is
# separate from CK3 updates and is meant to validate SteamCMD login/download
# behavior with a small target before a large CK3 run.
###############################################################################

# Small free Steam app ID used by the smoke test.
CK3QQBOT_STEAM_SMOKE_APP_ID=1079000

# Small Workshop item ID used by the smoke test.
CK3QQBOT_STEAM_SMOKE_WORKSHOP_ITEM_ID=2339078416

# Minimum free disk space in KiB required before the smoke test download.
CK3QQBOT_STEAM_SMOKE_MIN_FREE_KIB=1048576


###############################################################################
# Secret Handling Note
#
# Steam login uses cached state in CK3QQBOT_STEAMCMD_STATE. Do not put Steam
# passwords or Steam Guard codes in this file.
###############################################################################
